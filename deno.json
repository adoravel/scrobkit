{
	"tasks": {
		"dev": "deno run --watch main.ts",
		"tidy": "deno run -P=default mod.ts tidy",
		"import": "deno run -P=default mod.ts import",
		"export": "deno run -P=default mod.ts export"
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1.0.19",
		"@std/cli": "jsr:@std/cli@^1.0.29",
		"@std/crypto": "jsr:@std/crypto@^1.1.0",
		"@std/fmt": "jsr:@std/fmt@^1.0.10",
		"@std/fs": "jsr:@std/fs@^1.0.23",
		"@std/path": "jsr:@std/path@^1.1.4",
		"~/": "./"
	},
	"fmt": {
		"useTabs": true,
		"semiColons": true,
		"lineWidth": 120,
		"exclude": ["./third-party"]
	},
	"lint": {
		"rules": {
			"tags": ["recommended"],
			"exclude": ["no-explicit-any"]
		}
	},
	"test": {
		"permissions": {
			"read": true,
			"write": true
		},
		"include": ["tests/io/*.ts", "tests/codec/*.ts", "tests/*.ts"]
	}
}
